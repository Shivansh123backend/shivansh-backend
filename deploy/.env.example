# Copy to deploy/.env on each VPS (chmod 600, owner shivansh).
# Both VPS share most values; only VPS_ROLE and PRIMARY_HOST differ.

# ── Role (primary | secondary) ────────────────────────────────────────────────
VPS_ROLE=primary

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/shivansh

# ── Redis (required for the call queue when WORKER_ENABLED=true) ──────────────
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Worker ────────────────────────────────────────────────────────────────────
# On primary: true. On secondary: false (failover-monitor will flip it).
WORKER_ENABLED=true

# ── Public webhook URL (the hostname Telnyx calls back) ───────────────────────
WEBHOOK_BASE_URL=https://shivanshbackend.replit.app

# ── Telnyx ────────────────────────────────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_PUBLIC_KEY=

# ── Vapi ──────────────────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
# Get this from Vapi dashboard → Phone Numbers. Used as default outbound caller.
VAPI_PHONE_NUMBER_ID=

# ── Voice / AI ────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ── Sessions / auth ───────────────────────────────────────────────────────────
SESSION_SECRET=

# ── Email (optional — Resend takes priority if both set) ──────────────────────
RESEND_API_KEY=
SENDGRID_API_KEY=

# ── Failover (secondary VPS only) ─────────────────────────────────────────────
PRIMARY_HOST=
PRIMARY_PORT=8080
